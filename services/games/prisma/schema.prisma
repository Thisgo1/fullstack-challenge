// services/games/prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model Round {
  id          String   @id @default(uuid())
  status      String   // BETTING | RUNNING | CRASHED
  crashPoint  Int      // em centésimos (ex: 250 = 2.50x)
  seedHash    String   // hash público revelado antes da rodada
  seed        String?  // seed revelada após o crash
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  crashedAt   DateTime?
  bets        Bet[]
}

model Bet {
  id              String   @id
  roundId         String
  playerId        String
  amount          BigInt
  status          String   @default("PENDING")
  cashoutMultiplier Int?
  payout          BigInt?
  autoCashoutAt   Int?     // ← adicionar — null = manual
  createdAt       DateTime @default(now())
  round           Round    @relation(fields: [roundId], references: [id])
}
